# ===========================================
# Sigma AI Desktop Agent
# Environment Configuration
# ===========================================

APP_NAME=Sigma AI Desktop Agent
APP_VERSION=1.0.0
APP_ENV=development

# ---------- AI Providers ----------

OPENAI_API_KEY=

GEMINI_API_KEY=

ANTHROPIC_API_KEY=

# ---------- Browser ----------

DEFAULT_BROWSER=chrome

HEADLESS=false

# ---------- Database ----------

DATABASE_NAME=sigma.db

# ---------- Logging ----------

LOG_LEVEL=DEBUG

# ---------- Memory ----------

MEMORY_ENABLED=true

# ---------- Voice ----------

VOICE_ENABLED=false

# ---------- Vision ----------

VISION_ENABLED=false

# ---------- WhatsApp ----------

WHATSAPP_ENABLED=false